GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Use one of these MCP options.
# For a FastMCP HTTP/streamable-http server:
MCP_SERVER_URL=http://localhost:8001/mcp
MCP_TRANSPORT=streamable_http

# For an SSE server, use a URL ending in /sse or set MCP_TRANSPORT=sse.
# MCP_SERVER_URL=http://localhost:8001/sse
# MCP_TRANSPORT=sse

# For a local stdio server command instead of HTTP:
# MCP_SERVER_COMMAND=python /absolute/path/to/your/mcp_server.py
# Optional JSON object passed to the stdio MCP server process:
# MCP_SERVER_ENV_JSON={"SOME_SERVER_ENV":"value"}

# To connect multiple MCP servers, set MCP_SERVERS_JSON instead of the single-server
# values above. Tool names are exposed to the model as <serverName>__<toolName>.
# MCP_SERVERS_JSON=[
#   {"name":"crm","url":"http://localhost:8001/mcp","transport":"streamable_http"},
#   {"name":"docs","command":"python /absolute/path/to/docs_server.py","env":{"TOKEN":"value"}}
# ]

FRONTEND_ORIGIN=http://localhost:5173
REQUEST_TIMEOUT_SECONDS=45

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=app.log
LOG_MAX_BYTES=5000000
LOG_BACKUP_COUNT=5
